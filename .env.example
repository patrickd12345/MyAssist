# n8n Cloud: $vars / Custom Variables are Pro+ only (see README). On Starter, use Header Auth credentials in n8n instead of these names.

# MyAssist web app (apps/web) — server-only; copy to apps/web/.env.local for local dev
# MYASSIST_N8N_WEBHOOK_URL=https://YOUR_INSTANCE.app.n8n.cloud/webhook/myassist-daily-context
# MYASSIST_N8N_WEBHOOK_TOKEN=

# OpenAI (Custom GPT / other tools — not used by n8n myassist_unified.json)
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini

# Todoist
TODOIST_API_TOKEN=REPLACE_ME
TODOIST_PROJECT_INBOX_ID=REPLACE_ME
TODOIST_PROJECT_BOOKIJI_ID=REPLACE_ME
TODOIST_PROJECT_KINETIX_ID=REPLACE_ME
TODOIST_PROJECT_CHESS_ID=REPLACE_ME
TODOIST_PROJECT_PERSONAL_ID=REPLACE_ME
TODOIST_PROJECT_ADMIN_ID=REPLACE_ME

# Optional: if rebuilding Gmail triage automation (not shipped as JSON here)
TRIAGE_CONFIDENCE_THRESHOLD=0.65
# Allowed values: no_create, inbox
TRIAGE_LOW_CONFIDENCE_MODE=no_create

# Digest schedule documentation (Cron node controls runtime)
DIGEST_LOCAL_TIME=01:00

# Optional Gmail filter query for digest Gmail signals
# Default in workflow: label:starred newer_than:7d
GMAIL_SIGNAL_QUERY=label:starred newer_than:7d
