# Auth.js / NextAuth (required when MYASSIST_AUTH_DISABLED is not true)
# Generate: npx auth secret   (or any random string 32+ chars)
# Required for production builds and next start (NODE_ENV=production); dev uses a local fallback if unset.
AUTH_SECRET=
# Or legacy name:
# NEXTAUTH_SECRET=

# Public URL of this app (used by Auth.js; set in production)
AUTH_URL=http://localhost:3000

# Set to "true" only for automated tests or local debugging without login
# MYASSIST_AUTH_DISABLED=true
# MYASSIST_DEV_USER_ID=dev-user

# Optional: override user registry path (default: .myassist-memory/users.json)
# MYASSIST_USER_STORE_FILE=

# Optional: require this value as inviteCode on POST /api/auth/register (reduces open signup abuse)
# MYASSIST_REGISTRATION_INVITE_CODE=

# --- Hosted deployment (Vercel-friendly durable storage, Path A) ---
# When project URL + service role key are set, users and encrypted OAuth rows are stored in Supabase Postgres (schema myassist).
# Migrations: ../../supabase/migrations/
#
# Project URL (same value for all Bookiji products on the shared project). Use any ONE of:
# SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co   # ok if you already have this from Kinetix / Next
# VITE_SUPABASE_URL=https://xxxx.supabase.co          # ok if copied from a Vite app
#
# REQUIRED for server-side writes (myassist.app_users / myassist.integration_tokens). NOT the anon / publishable key.
# New projects (legacy JWT keys disabled): use the project secret key:
# SUPABASE_SECRET_KEY=   # Dashboard → Settings → API → Secret key (sb_secret_...). Server only.
# If legacy API keys are still enabled, JWT service_role also works:
# SUPABASE_SERVICE_ROLE_KEY=
#
# NOT used by MyAssist hosted stores: VITE_SUPABASE_ANON_KEY, NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY, SUPABASE_ACCESS_TOKEN (CLI / unrelated).

# Strongly recommended in production so integration tokens survive AUTH_SECRET rotation (32-byte base64 or any string; see apps/web/README.md)
# MYASSIST_INTEGRATIONS_ENCRYPTION_KEY=

# --- Error monitoring (optional) ---
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Set to true to serve demo daily context instead of live Gmail / Calendar / Todoist reads
# MYASSIST_USE_MOCK_CONTEXT=true

# Per-user Todoist API token can be stored in the local user registry after registration
# (apps/web/.myassist-memory/users.json) when not using Todoist OAuth.

# IANA timezone for Todoist task day bucketing (Overdue / Today). Default: America/Toronto
# MYASSIST_TASK_DAY_TZ=America/Toronto

# Job Hunt digest (job-hunt-manager). Default if unset: http://127.0.0.1:3847/digest
# Start digest: pnpm job-hunt:digest:dev (from repo root)
# GET /api/job-hunt/resolve runs job-hunt-manager on the Next server (same JOB_HUNT_DATA_PATH store); digest HTTP is not required for Find or fetch.
# Notes → contact extraction (Add by job id → Save) uses the same Ollama vars as the assistant (OLLAMA_BASE_URL, OLLAMA_MODEL); if Ollama is down, email/phone heuristics still run.
# JOB_HUNT_DIGEST_URL=http://127.0.0.1:3847/digest
# Email→job matching (POST). Default: same host as JOB_HUNT_DIGEST_URL with path /signals, else http://127.0.0.1:3847/signals
# JOB_HUNT_SIGNALS_URL=http://127.0.0.1:3847/signals
# MYASSIST_DISABLE_JOB_HUNT_SIGNALS=true

# Optional: path to rss-sources.json (defaults next to the job-hunt store file)
# JOB_HUNT_RSS_SOURCES_FILE=
# RSS URLs can also be set in the Job Hunt page UI (writes the same file).
# JOB_HUNT_* env vars still apply when a source is not overridden in rss-sources.json
# LinkedIn (guest search; one URL). Example: Greater Montreal + AI (current UI params are fine)
# JOB_HUNT_LINKEDIN_RSS_URLS=https://www.linkedin.com/jobs/search/?currentJobId=4383375251&geoId=90009540&keywords=Ai&origin=JOB_SEARCH_PAGE_JOB_FILTER
