# Supabase Auth (required when MYASSIST_AUTH_DISABLED is not true)
# Team dev: store these in Infisical path `/myassist` (dev) and run `pnpm dev:infisical` from apps/web or repo root.
AUTH_SECRET=
# Public URL of this app (used for redirect targets). For this deployment, use the MyAssist origin, not a sibling product.
AUTH_URL=http://localhost:3000
# Required on Vercel / production: canonical MyAssist public origin. Supabase OAuth and magic links use this for `redirectTo`; if unset, the **browser** origin is used (wrong if users open a sibling Bookiji app). `pnpm run check:env:prod` enforces this.
# Local: match your dev port.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared DB tier guardrails (Infisical)
# local + preview should resolve to dev; production resolves to prod.
# SHARED_DB_TIER=dev
# SHARED_DB_ENV_STRICT=1
# Optional: Supabase project refs (hostname segment before .supabase.co) for strict URL vs deployment tier checks:
# SHARED_DB_DEV_PROJECT_REF=
# SHARED_DB_PROD_PROJECT_REF=

# Set to "true" only for automated tests or local debugging without login
# MYASSIST_AUTH_DISABLED=true
# MYASSIST_DEV_USER_ID=dev-user

# Optional: override user registry path (default: .myassist-memory/users.json)
# MYASSIST_USER_STORE_FILE=

# Optional: require this value as inviteCode on POST /api/auth/register (reduces open signup abuse)
# MYASSIST_REGISTRATION_INVITE_CODE=

# Optional: absolute directory for file-backed memory (rolling memory, daily snapshot cache, local integration JSON).
# Default: .myassist-memory under cwd locally; on Vercel, /tmp/myassist-memory (writable, ephemeral) unless you set this.
# MYASSIST_MEMORY_ROOT=

# --- Hosted deployment (Vercel-friendly durable storage, Path A) ---
# When project URL + service role key are set, users and encrypted OAuth rows are stored in Supabase Postgres (schema myassist).
# Migrations: ../../supabase/migrations/
#
# Project URL (same value for all Bookiji products on the shared project). Use any ONE of:
# SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co   # ok if you already have this from Kinetix / Next
# VITE_SUPABASE_URL=https://xxxx.supabase.co          # ok if copied from a Vite app
#
# REQUIRED for server-side writes (myassist.app_users / myassist.integration_tokens). NOT the anon / publishable key.
# New projects (legacy JWT keys disabled): use the project secret key:
# SUPABASE_SECRET_KEY=   # Dashboard â†’ Settings â†’ API â†’ Secret key (sb_secret_...). Server only.
# If legacy API keys are still enabled, JWT service_role also works:
# SUPABASE_SERVICE_ROLE_KEY=
# High risk: do not rotate casually; coordinate rollout across every deployment that reads shared data.
#
# Supabase Auth (forgot/reset) also accepts anon/publishable keys from:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# VITE_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_ANON_KEY=
#
# SUPABASE_ACCESS_TOKEN is still unrelated (CLI token).

# AES-256-GCM key for encrypting OAuth tokens at rest (integrations.json locally; myassist.integration_tokens in Supabase).
# If unset, the app hashes AUTH_SECRET (or a fixed dev string when AUTH_SECRET is missing). That is fine for local-only file storage,
# but set an explicit key for production so tokens stay readable after you rotate AUTH_SECRET, and use the SAME value on every
# deploy (Vercel) that must decrypt existing rows.
#
# Generate a 32-byte key as base64 (paste into .env.local and Vercel):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Or use any long random string (it will be SHA-256'd to 32 bytes â€” slightly weaker than raw 32-byte base64).
MYASSIST_INTEGRATIONS_ENCRYPTION_KEY=

# --- Error monitoring (optional) ---
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Assistant AI (see docs/commercial-pilot-readiness.md "AI inference") ---
# Default: ollama at http://127.0.0.1:11434 â€” fine for local dev when Ollama runs on the same machine as Next.
# Hosted serverless: use gateway (OpenAI-compatible) OR a reachable Ollama URL â€” not localhost.
#
# AI_MODE=ollama | gateway | fallback
# - ollama (default if unset): uses OLLAMA_* below
# - gateway: uses VERCEL_AI_BASE_URL + key + OPENAI_MODEL / AI_GATEWAY_MODEL
# - fallback: deterministic assistant only
# AI_MODE=ollama
#
# Ollama (local or remote)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_API_URL=   # alias for OLLAMA_BASE_URL
# OLLAMA_MODEL=tinyllama:latest
# LLM_MODEL=        # alias for OLLAMA_MODEL
# Comma-separated try-order for headline / situation paths when not in gateway mode:
# OLLAMA_HEADLINE_MODELS=mistral:latest,qwen2.5:0.5b
# OLLAMA_SITUATION_MODELS=
# OLLAMA_EMAIL_IMPORTANCE_MODEL=
# OLLAMA_EMAIL_IMPORTANCE_MODELS=
#
# Gateway (OpenAI-compatible chat completions at {VERCEL_AI_BASE_URL}/v1/chat/completions)
# AI_MODE=gateway
# VERCEL_AI_BASE_URL=https://api.openai.com
# AI_GATEWAY_BASE_URL=   # alias
# VERCEL_VIRTUAL_KEY=
# AI_GATEWAY_API_KEY=    # alias
# OPENAI_API_KEY=        # alias for bearer token
# OPENAI_MODEL=gpt-4o-mini
# AI_GATEWAY_MODEL=      # alias for OPENAI_MODEL

# Curated demo dataset (no live provider reads). Takes precedence over MYASSIST_USE_MOCK_CONTEXT. For demos only.
# MYASSIST_DEMO_MODE=true

# Set to true to serve minimal mock daily context instead of live Gmail / Calendar / Todoist reads
# MYASSIST_USE_MOCK_CONTEXT=true

# OAuth connect/callback debug (localhost ingest + structured log). Off by default.
# MYASSIST_DEBUG_OAUTH=true

# Optional: add ai-runtime one-line daily intelligence summary (executeChat). Off by default; deterministic buckets always run.
# MYASSIST_DAILY_INTEL_AI=true

# Per-user Todoist API token can be stored in the local user registry after registration
# (apps/web/.myassist-memory/users.json) when not using Todoist OAuth.

# IANA timezone for Todoist task day bucketing (Overdue / Today). Default: America/Toronto
# Use NEXT_PUBLIC_* so the dashboard client bundle matches server bucketing (see lib/todoistTaskBuckets.ts).
# NEXT_PUBLIC_MYASSIST_TASK_DAY_TZ=America/Toronto
# MYASSIST_TASK_DAY_TZ=America/Toronto

# Job Hunt digest (job-hunt-manager). Default if unset: http://127.0.0.1:3847/digest
# Start digest: pnpm job-hunt:digest:dev (from repo root)
# GET /api/job-hunt/resolve runs job-hunt-manager on the Next server (same JOB_HUNT_DATA_PATH store); digest HTTP is not required for Find or fetch.
# Notes â†’ contact extraction (Add by job id â†’ Save) uses the same Ollama vars as the assistant (OLLAMA_BASE_URL, OLLAMA_MODEL); if Ollama is down, email/phone heuristics still run.
# JOB_HUNT_DIGEST_URL=http://127.0.0.1:3847/digest
# Emailâ†’job matching (POST). Default: same host as JOB_HUNT_DIGEST_URL with path /signals, else http://127.0.0.1:3847/signals
# JOB_HUNT_SIGNALS_URL=http://127.0.0.1:3847/signals
# MYASSIST_DISABLE_JOB_HUNT_SIGNALS=true

# Optional: path to rss-sources.json (defaults next to the job-hunt store file)
# JOB_HUNT_RSS_SOURCES_FILE=
# RSS URLs can also be set in the Job Hunt page UI (writes the same file).
# JOB_HUNT_* env vars still apply when a source is not overridden in rss-sources.json
# LinkedIn (guest search; one URL). Example: Greater Montreal + AI (current UI params are fine)
# JOB_HUNT_LINKEDIN_RSS_URLS=https://www.linkedin.com/jobs/search/?currentJobId=4383375251&geoId=90009540&keywords=Ai&origin=JOB_SEARCH_PAGE_JOB_FILTER

# --- Google OAuth (Gmail + Calendar; Web application client) ---
# Create in Google Cloud Console â†’ APIs & Services â†’ Credentials â†’ OAuth 2.0 Client IDs (Web).
# Authorized redirect URI (one for both Gmail and Calendar): {AUTH_URL}/api/integrations/google/callback
# Example local: http://localhost:3000/api/integrations/google/callback
# Gmail MVP scopes are defined in code as GMAIL_MVP_OAUTH_SCOPES (read-only; no gmail.modify).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Aliases also accepted: MYASSIST_GMAIL_CLIENT_ID, MYASSIST_GOOGLE_CLIENT_ID, MYASSIST_GMAIL_CLIENT_SECRET, MYASSIST_GOOGLE_CLIENT_SECRET

# --- BKI-019 login providers (Supabase OAuth) ---
# Configure providers in Supabase Auth and set a redirect URL that returns to your app
# (for example {AUTH_URL}/ or {AUTH_URL}/sign-in depending on your flow).
#
# Microsoft / Outlook login:
# Configure in Supabase Auth provider settings and in Azure / Microsoft Entra ID app registration.
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# Optional tenant pin. If unset, Auth.js uses the provider default.
# MICROSOFT_TENANT_ID=
# Aliases also accepted: MICROSOFT_ENTRA_ID_CLIENT_ID, AUTH_MICROSOFT_ENTRA_ID_ID, AZURE_AD_CLIENT_ID
# and MICROSOFT_ENTRA_ID_CLIENT_SECRET, AUTH_MICROSOFT_ENTRA_ID_SECRET, AZURE_AD_CLIENT_SECRET
# Tenant aliases also accepted: MICROSOFT_ENTRA_ID_TENANT_ID, AUTH_MICROSOFT_ENTRA_ID_TENANT_ID, AZURE_AD_TENANT_ID

# --- BKI-019 password reset email (production) ---
# Forgot-password never exposes reset tokens in production. When a matching account exists, the reset link is sent via Resend.
# RESEND_API_KEY=
# MYASSIST_PASSWORD_RESET_EMAIL_FROM=MyAssist <reset@yourdomain.com>
# Aliases also accepted: MYASSIST_RESEND_API_KEY, PASSWORD_RESET_EMAIL_FROM, RESEND_FROM_EMAIL

# --- Today auto-refresh (client) ---
# Age in ms after `generated_at` before silent background refresh may run (tab visible, at least one integration connected).
# Example: 300000 = 5 minutes. Minimum enforced in code: 60 seconds.
# NEXT_PUBLIC_MYASSIST_AUTO_REFRESH_STALE_MS=600000

# --- MCP / agent clients (Bearer: /api/mcp/daily-context, action-candidates, approve, execute) ---
# Long random secret; must match apps/myassist-mcp MYASSIST_MCP_TOKEN when using the stdio MCP server.
# MYASSIST_MCP_TOKEN=
# User id whose OAuth tokens and provider reads are used (same as session user id in Supabase or file store).
# MYASSIST_MCP_USER_ID=
# Optional: multi-client map (non-empty list disables legacy MYASSIST_MCP_TOKEN + MYASSIST_MCP_USER_ID for MCP routes).
# Example: [{"bearerToken":"long-random-1","userId":"<uuid>"},{"bearerToken":"long-random-2","userId":"<other-uuid>"}]
# MYASSIST_MCP_CLIENTS_JSON=
# Optional: path to JSON file with the same array shape as MYASSIST_MCP_CLIENTS_JSON (used if MYASSIST_MCP_CLIENTS_JSON is unset or empty).
# MYASSIST_MCP_CLIENTS_FILE=
# Optional: signing key for POST /api/mcp/approve tokens (recommended in production). If unset, derived from MYASSIST_MCP_TOKEN or client-list config.
# MYASSIST_ACTION_APPROVAL_SECRET=
